MARIADB_USER=
MARIADB_PASSWORD=
MARIADB_HOST=
MARIADB_DATABASE=

# Cloudflare R2 (optional; required only for bulk dumps listing)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Auth (required for login/session tokens)
AUTH_SECRET_KEY=

# Optional: separate auth DB (recommended in production)
# Example: postgresql://user:pass@host:5432/dbname
# Note: if you leave this blank but set DATABASE_URL, the backend will use DATABASE_URL for auth.
AUTH_DATABASE_URI=

# Google OAuth (server-side; never put secrets in the frontend)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Public URLs used to build OAuth redirect URIs
PUBLIC_API_BASE_URL=http://localhost:5113
PUBLIC_FRONTEND_BASE_URL=http://localhost:8080

# MCP / external OAuth resource-server auth
# For ZITADEL-backed MCP, set MCP_IDENTITY_PROVIDER=zitadel and point these values
# at the ZITADEL instance that issues access tokens for the MCP resource.
MCP_IDENTITY_PROVIDER=oidc
MCP_PUBLIC_BASE_URL=
MCP_RESOURCE_URL=
MCP_SERVER_NAME=pandects-mcp
MCP_SERVER_VERSION=0.1.0
MCP_SUPPORTED_SCOPES=sections:search,agreements:search,agreements:read,agreements:read_fulltext
MCP_OIDC_ISSUER=
MCP_OIDC_AUTHORIZATION_SERVER_URL=
MCP_OIDC_AUDIENCE=
MCP_OIDC_JWKS_URL=
MCP_OIDC_DISCOVERY_URL=
MCP_OIDC_INTROSPECTION_ENDPOINT=
MCP_OIDC_INTROSPECTION_CLIENT_ID=
MCP_OIDC_INTROSPECTION_CLIENT_SECRET=
MCP_OIDC_SIGNING_ALGORITHMS=

# Website auth cutover (optional overrides for ZITADEL-backed website sign-in)
# Default redirect target is {PUBLIC_FRONTEND_BASE_URL}/auth/zitadel/callback
AUTH_ZITADEL_REDIRECT_URI=
# Optional: set this to the upstream Google IdP hint in ZITADEL if you want
# "Continue with Google" to bypass the generic ZITADEL chooser.
AUTH_ZITADEL_GOOGLE_IDP_HINT=

# Optional: explicit CORS origin allowlist for /v1/*.
# If set, this REPLACES backend defaults, so include docs + frontend origins you need.
# CORS_ORIGINS=http://localhost:3001,http://localhost:8080,https://pandects.org,https://docs.pandects.org

# Main DB reflection controls
# Enable reflection of main-db tables at startup/import (default: enabled).
ENABLE_MAIN_DB_REFLECTION=1
# Skip main-db reflection (used in tests/local offline workflows; default: disabled).
SKIP_MAIN_DB_REFLECTION=0

# Search count approximation controls
# Use EXPLAIN-based estimate for filtered search totals (default: enabled).
SEARCH_EXPLAIN_ESTIMATE_ENABLED=1

# In-memory rate limit guardrails
# Upper bound for in-memory rate-limit key cardinality (default: 50000).
RATE_LIMIT_MAX_KEYS=50000
# How often in-memory rate-limit maps are pruned, in seconds (default: 30).
RATE_LIMIT_PRUNE_INTERVAL_SECONDS=30

# API key last-used write throttling
# Minimum seconds between persisted last_used_at updates per key (default: 300).
API_KEY_LAST_USED_TOUCH_SECONDS=300
# Upper bound for in-memory API-key touch state cardinality (default: 50000).
API_KEY_LAST_USED_MAX_KEYS=50000

# Email verification (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_TEMPLATE_ID=
# Password reset (Resend template id; default "forgot-password")
RESEND_FORGOT_PASSWORD_TEMPLATE_ID=
# Optional (default: 7 days)
EMAIL_VERIFICATION_TOKEN_MAX_AGE_SECONDS=
# Optional (default: 1 hour)
PASSWORD_RESET_TOKEN_MAX_AGE_SECONDS=
