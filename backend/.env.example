# Public-safe local defaults
PUBLIC_API_BASE_URL=http://localhost:5113
PUBLIC_FRONTEND_BASE_URL=http://localhost:8080
AUTH_SESSION_TRANSPORT=bearer
SKIP_MAIN_DB_REFLECTION=1
ENABLE_MAIN_DB_REFLECTION=1

# Optional local-safe behavior tuning
# CORS_ORIGINS=http://localhost:3001,http://localhost:8080
FILTER_OPTIONS_TTL_SECONDS=21600
DUMPS_CACHE_TTL_SECONDS=300
DUMPS_MANIFEST_CACHE_TTL_SECONDS=1800
SEARCH_EXPLAIN_ESTIMATE_ENABLED=1
RATE_LIMIT_MAX_KEYS=50000
RATE_LIMIT_PRUNE_INTERVAL_SECONDS=30
API_KEY_LAST_USED_TOUCH_SECONDS=300
API_KEY_LAST_USED_MAX_KEYS=50000
USAGE_SAMPLE_RATE_2XX=0.05
USAGE_SAMPLE_RATE_3XX=0.05
USAGE_LOG_BUFFER_ENABLED=1
USAGE_LOG_BUFFER_FLUSH_SECONDS=1
USAGE_LOG_BUFFER_MAX_EVENTS=200
ASYNC_SIDE_EFFECTS_ENABLED=1
ASYNC_SIDE_EFFECTS_MAX_QUEUE=100

# Optional auth DB override
# Leave blank to use the local sqlite auth DB.
AUTH_DATABASE_URI=

# Optional main DB override
# Outside contributors should typically leave main DB settings blank and keep
# SKIP_MAIN_DB_REFLECTION=1.
MAIN_DATABASE_URI=
MAIN_DB_SCHEMA=
MARIADB_USER=
MARIADB_PASSWORD=
MARIADB_HOST=
MARIADB_DATABASE=

# Optional public-safe MCP metadata
MCP_IDENTITY_PROVIDER=oidc
MCP_PUBLIC_BASE_URL=
MCP_SERVER_NAME=pandects-mcp
MCP_SERVER_VERSION=0.1.0
MCP_SUPPORTED_SCOPES=sections:search,agreements:search,agreements:read,agreements:read_fulltext

# Maintainer-only identity and OAuth integrations
AUTH_SECRET_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MCP_OIDC_ISSUER=
MCP_OIDC_AUTHORIZATION_SERVER_URL=
MCP_OIDC_AUTHORIZATION_ENDPOINT=
MCP_OIDC_TOKEN_ENDPOINT=
MCP_OIDC_AUDIENCE=
MCP_OIDC_JWKS_URL=
MCP_OIDC_DISCOVERY_URL=
MCP_OIDC_INTROSPECTION_ENDPOINT=
MCP_OIDC_INTROSPECTION_CLIENT_ID=
MCP_OIDC_INTROSPECTION_CLIENT_SECRET=
MCP_OIDC_SIGNING_ALGORITHMS=
MCP_ZITADEL_CLIENT_ID=
MCP_ZITADEL_REDIRECT_URI=
MCP_ZITADEL_SCOPES=
MCP_ZITADEL_AUDIENCE=
MCP_ZITADEL_RESOURCE=
MCP_ZITADEL_ROLE_SCOPE_MAP=
AUTH_ZITADEL_REDIRECT_URI=
AUTH_ZITADEL_GOOGLE_IDP_HINT=
AUTH_ZITADEL_API_TOKEN=
AUTH_ZITADEL_API_CLIENT_ID=
AUTH_ZITADEL_API_KEY_ID=
AUTH_ZITADEL_API_PRIVATE_KEY=
AUTH_ZITADEL_GOOGLE_IDP_ID=
AUTH_ZITADEL_DEFAULT_ROLE_KEYS=
AUTH_ZITADEL_PROJECT_ID=
AUTH_ZITADEL_NOTIFICATION_SIGNING_KEY=
AUTH_ZITADEL_NOTIFICATION_MAX_AGE_SECONDS=300
TURNSTILE_ENABLED=0
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Maintainer-only delivery and bulk integrations
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=Pandects
