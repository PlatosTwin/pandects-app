\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Eligible agreements by filing year in the filtered all-cash public-deal sample used for the forum-selection analysis.}}{19}{figure.caption.12}\protected@file@percent }
\newlabel{fig:filtered-sample-agreements-by-year}{{1}{19}{Eligible agreements by filing year in the filtered all-cash public-deal sample used for the forum-selection analysis}{figure.caption.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Forum-selection prevalence in the all-cash public-deal sample. Forum-selection clauses become common early in the sample and remain prevalent thereafter, though prevalence falls below its peak in recent years. The shaded area represents a bootstrapped 95\% confidence interval. \emph  {All eligible deals + Universe A.}}}{19}{figure.caption.13}\protected@file@percent }
\newlabel{fig:forum-clause-prevalence}{{2}{19}{Forum-selection prevalence in the all-cash public-deal sample. Forum-selection clauses become common early in the sample and remain prevalent thereafter, though prevalence falls below its peak in recent years. The shaded area represents a bootstrapped 95\% confidence interval. \emph {All eligible deals + Universe A.}}{figure.caption.13}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Forum-selection clause length (A), readability (B), and complexity (C) over time. Each chart evidences the pattern Coates describes through 2014—increasing length and complexity. However, following 2014, median clause length, readability, and our custom proxy for complexity all plateau or even witness declines. \emph  {Universe B.}}}{20}{figure.caption.14}\protected@file@percent }
\newlabel{fig:forum-clause-length-complexity}{{3}{20}{Forum-selection clause length (A), readability (B), and complexity (C) over time. Each chart evidences the pattern Coates describes through 2014—increasing length and complexity. However, following 2014, median clause length, readability, and our custom proxy for complexity all plateau or even witness declines. \emph {Universe B.}}{figure.caption.14}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Delaware and New York shares among agreements with eligible forum-selection clauses. Delaware remains the dominant forum throughout the sample, but beginning in 2010 shares priority with New York; New York's share, however, peaks in 2013, and declines substantially in the final years of the sample. \emph  {Universe A.}}}{20}{figure.caption.15}\protected@file@percent }
\newlabel{fig:forum-clause-delaware-new-york}{{4}{20}{Delaware and New York shares among agreements with eligible forum-selection clauses. Delaware remains the dominant forum throughout the sample, but beginning in 2010 shares priority with New York; New York's share, however, peaks in 2013, and declines substantially in the final years of the sample. \emph {Universe A.}}{figure.caption.15}{}}
\BKM@entry{id=13,dest={73656374696F6E2E34},srcline={421},srcfile={2F55736572732F6E696B697461626F6764616E6F762F5079636861726D50726F6A656374732F6D65726765725F61677265656D656E74732F61707076322F70617065722F696E74726F647563696E675F70616E64656374732E746578}}{5C3337365C3337375C303030435C3030306F5C3030306E5C303030635C3030306C5C303030755C303030735C303030695C3030306F5C3030306E}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Phrase shifts in Delaware-only forum-selection clauses across five-year periods. Note the rise of ``delaware court of chancery'' and the decline of both ``district of delaware'' and ``any delaware state court.'' Also interesting is the rise of ``relating to this agreement or the transactions,'' which did not exist at all in early-period agreements. \emph  {Universe B.}}}{21}{figure.caption.16}\protected@file@percent }
\newlabel{fig:forum-clause-phrase-shift-five-periods}{{5}{21}{Phrase shifts in Delaware-only forum-selection clauses across five-year periods. Note the rise of ``delaware court of chancery'' and the decline of both ``district of delaware'' and ``any delaware state court.'' Also interesting is the rise of ``relating to this agreement or the transactions,'' which did not exist at all in early-period agreements. \emph {Universe B.}}{figure.caption.16}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Substantive phrase shifts in Delaware-only forum-selection clauses across five-year periods. Compared with the broader phrase plot above, this figure removes ``stop words'' to focus (ideally) on differences in substantive phrases. Similar to above, we can see here the rising preference for Chancery Court over just any Delaware court, and the rise of ``related transactions'' language. \emph  {Universe B.}}}{21}{figure.caption.17}\protected@file@percent }
\newlabel{fig:forum-clause-substantive-phrase-shift-five-periods}{{6}{21}{Substantive phrase shifts in Delaware-only forum-selection clauses across five-year periods. Compared with the broader phrase plot above, this figure removes ``stop words'' to focus (ideally) on differences in substantive phrases. Similar to above, we can see here the rising preference for Chancery Court over just any Delaware court, and the rise of ``related transactions'' language. \emph {Universe B.}}{figure.caption.17}{}}
